import pandas as pd
from pathlib import Path
from stg import (
    evaluate as evaluate_synth_data, # this is the main entry point for evaluation
    generate_column_name_to_datatype,
)


# ==== Paths ====
BASE_DIR = Path(__file__).resolve().parent
DATA_DIR = BASE_DIR / "test_data"
SYNTH_DIR = BASE_DIR / "synth_data"
EVAL_OUTPUT_DIR = BASE_DIR / "eval_outputs"
EVAL_OUTPUT_DIR.mkdir(exist_ok=True)

# Evaluate every synthetic CSV generated by train/generate scripts.
synth_files = sorted(SYNTH_DIR.glob("*.csv"))
if not synth_files:
    raise FileNotFoundError(f"No synthetic CSV files found in {SYNTH_DIR.resolve()}")


# Optional per-dataset overrides. If empty, metadata is inferred from real CSV dtypes
# and target defaults to the last column.
COLUMN_NAME_TO_DATATYPE_OVERRIDES = {}
TARGET_COLUMN_OVERRIDES = {}


for synth_path in synth_files:
    run_name = synth_path.stem
    # Expected naming convention from generation phase: <dataset>__<model>.csv
    if "__" not in run_name:
        print(f"Skipping {synth_path.name}: expected format <dataset>__<model>.csv")
        continue

    # Parse dataset/model from the synth filename so we can pair with real data.
    dataset_name, model_name = run_name.rsplit("__", 1)
    real_path = DATA_DIR / f"{dataset_name}.csv"

    # Each synthetic file must map back to a real dataset file.
    if not real_path.exists():
        print(f"Skipping {synth_path.name}: no matching real CSV at {real_path}")
        continue

    print(f"\n=== Evaluating: {dataset_name} / {model_name} ===")

    try:
        real_df = pd.read_csv(real_path)
        real_df = real_df.dropna(axis=1, how="all").dropna(axis=0, how="all")

        # Build evaluator metadata from real data unless dataset-specific overrides are provided.
        column_name_to_datatype = COLUMN_NAME_TO_DATATYPE_OVERRIDES.get(
            dataset_name, generate_column_name_to_datatype(real_df)
        )
        # Utility metrics require a target column; default to the last real-data column.
        target_column = TARGET_COLUMN_OVERRIDES.get(dataset_name, real_df.columns[-1])
        eval_config = {
            "target_column": target_column,
        }

        # Store outputs per run using the requested folder format: <model>__<dataset>.
        eval_save_dir = EVAL_OUTPUT_DIR / f"{model_name}__{dataset_name}"
        eval_save_dir.mkdir(parents=True, exist_ok=True)

        # Main evaluator call: compares real CSV vs synthetic CSV and writes tables/plots.
        report = evaluate_synth_data(
            real_data_path=real_path,
            synth_data_path=synth_path,
            column_name_to_datatype=column_name_to_datatype,
            config=eval_config,
            save_path=eval_save_dir,
        )

        print(f"Saved evaluation outputs to: {eval_save_dir}")
        print(
            f"tables={len(report.get('tables', {}))}, "
            f"plots={len(report.get('plots', {}))}"
        )
    except Exception as e:
        print(f"*** Skipping {dataset_name} / {model_name} due to error: {type(e).__name__}: {e}")
